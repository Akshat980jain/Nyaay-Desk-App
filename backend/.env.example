# ─── FIX #2 & #10: Environment Variable Template ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control. Only commit .env.example.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Authentication
# Use a long, random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# Email (SendGrid)
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_API_KEY
FROM_EMAIL=youremail@yourdomain.com

# AI
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# CORS — comma-separated list of allowed frontend origins
# Example: http://localhost:3000,https://ecourtfiling.onrender.com
CORS_ORIGINS=http://localhost:3000

# Blockchain Keys (RSA)
RSA_PRIVATE_KEY_PATH=./blockchain/keys/private.pem
RSA_PUBLIC_KEY_PATH=./blockchain/keys/public.pem
RSA_PUBLIC_KEY_FINGERPRINT=REPLACE_WITH_YOUR_KEY_FINGERPRINT

# Optional — used in email templates
LOGO_URL=https://yourdomain.com/logo.png
SUPPORT_URL=https://yourdomain.com/support
PRIVACY_URL=https://yourdomain.com/privacy
TERMS_URL=https://yourdomain.com/terms
